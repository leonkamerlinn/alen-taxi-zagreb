# ─────────────────────────────────────────────────────────────────────────────
# Fingerprint Pro + admin dashboard configuration
#
# Copy this file to `.env` for local development:   cp .env.example .env
# In production (Cloud Run) set these as env vars / Secret Manager secrets instead.
# Nuxt automatically maps NUXT_* / NUXT_PUBLIC_* vars onto runtimeConfig.
# See docs/FINGERPRINT_SETUP.md for the full setup walkthrough.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server-only secrets (NEVER expose to the browser) ───────────────────────────

# Fingerprint Pro "Secret API key" (Dashboard → API Keys). Used server-side only.
NUXT_FINGERPRINT_SECRET_API_KEY=

# Password to log in to /dashboard.
NUXT_ADMIN_PASSWORD=change-me

# Random secret used to sign the admin session + visitor cookies.
# Generate one with:  openssl rand -hex 32
NUXT_SESSION_SECRET=

# ── Public (shipped to the browser — safe to expose) ────────────────────────────

# Fingerprint Pro "Public API key" (Dashboard → API Keys). Lock it to your domain.
NUXT_PUBLIC_FINGERPRINT_PUBLIC_API_KEY=

# Workspace region — MUST match the region chosen at signup. Use "eu" for GDPR/Croatia.
NUXT_PUBLIC_FINGERPRINT_REGION=eu

# Optional: custom first-party subdomain for the identification API (Safari ITP).
# Leave empty to use Fingerprint's default endpoint. Example: https://metrics.yourdomain.com
NUXT_PUBLIC_FINGERPRINT_ENDPOINT=

# Optional: custom URL pattern for loading the agent script through your subdomain.
# Leave empty to load from Fingerprint's CDN. The dashboard shows the exact value
# when you set up the subdomain. Example:
#   https://metrics.yourdomain.com/web/v<version>/<apiKey>/loader_v<loaderVersion>.js
NUXT_PUBLIC_FINGERPRINT_SCRIPT_URL_PATTERN=
